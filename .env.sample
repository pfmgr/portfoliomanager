# Copy to `.env` (this file is gitignored) and fill in secrets.

# Database
PORTFOLIO_DB_PASSWORD=change-me
METABASE_DB_PASSWORD=change-me

# Admin UI auth (Basic Auth + JWT)
ADMIN_USER=admin
ADMIN_PASS=change-me
JWT_SECRET=change-me-change-me-change-me-change-me
JWT_JTI_HASH_SECRET=change-you-change-you-change-you-change-you
JWT_ISSUER=portfolio-manager

# Bind addresses (keep local by default)
ADMIN_SPRING_BIND=127.0.0.1
ADMIN_FRONTEND_BIND=127.0.0.1

# Knowledge Base (KB)
# - KB endpoints are gated by KB_ENABLED and an enabled LLM provider
KB_ENABLED=true

# - Enables the (currently stubbed) LlmExtractorService for dossier extraction runs
KB_LLM_ENABLED=false

# LLM provider (currently only OpenAI is supported)
# - Global fallback used by all LLM actions unless action-specific values are set.
LLM_PROVIDER=openai
LLM_PROVIDER_MODEL=gpt-5-nano
LLM_PROVIDER_BASE_URL=https://api.openai.com/v1

# Prefer LLM_PROVIDER_API_KEY; OPENAI_API_KEY is supported as a fallback.
LLM_PROVIDER_API_KEY=
#OPENAI_API_KEY=

# Optional action-specific overrides (fallback to global LLM_PROVIDER_* when empty):
# - Websearch action is used for KB websearch + alternatives.
LLM_WEBSEARCH_PROVIDER=
LLM_WEBSEARCH_PROVIDER_MODEL=
LLM_WEBSEARCH_PROVIDER_BASE_URL=
LLM_WEBSEARCH_PROVIDER_API_KEY=

# - Extraction action is used for KB extraction.
LLM_EXTRACTION_PROVIDER=
LLM_EXTRACTION_PROVIDER_MODEL=
LLM_EXTRACTION_PROVIDER_BASE_URL=
LLM_EXTRACTION_PROVIDER_API_KEY=

# - Narrative action is used for rebalancer/assessor narratives.
LLM_NARRATIVE_PROVIDER=
LLM_NARRATIVE_PROVIDER_MODEL=
LLM_NARRATIVE_PROVIDER_BASE_URL=
LLM_NARRATIVE_PROVIDER_API_KEY=
