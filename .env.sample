# Copy to `.env` (this file is gitignored) and fill in secrets.

# Database
PORTFOLIO_DB_PASSWORD=change-me

# Admin UI auth (Basic Auth + JWT)
ADMIN_USER=admin
ADMIN_PASS=change-me
JWT_SECRET=change-me-change-me-change-me-change-me
JWT_JTI_HASH_SECRET=change-you-change-you-change-you-change-you
JWT_ISSUER=portfolio-manager

# Bind addresses (keep local by default)
ADMIN_SPRING_BIND=127.0.0.1
ADMIN_SPRING_PORT=8089
ADMIN_FRONTEND_BIND=127.0.0.1
ADMIN_FRONTEND_PORT=8080
ADMIN_FRONTEND_CONTAINER_PORT=80

# Frontend TLS (optional)
ADMIN_FRONTEND_TLS_ENABLED=false
ADMIN_FRONTEND_TLS_SELF_SIGNED=false
ADMIN_FRONTEND_TLS_BIND=127.0.0.1
ADMIN_FRONTEND_TLS_PORT=8443
ADMIN_FRONTEND_TLS_SAN_NAMES=localhost,127.0.0.1
ADMIN_FRONTEND_TLS_CERT_PATH=
ADMIN_FRONTEND_TLS_KEY_PATH=
STACK_ALLOW_INSECURE_TLS=false

# Knowledge Base (KB)
# - KB endpoints are gated by KB_ENABLED and an enabled LLM provider
KB_ENABLED=true

# - Enables the (currently stubbed) LlmExtractorService for dossier extraction runs
KB_LLM_ENABLED=false

# LLM API keys are now configured via UI and stored encrypted in DB.
# Set this to a high-entropy secret to enable editing of LLM config in UI.
LLM_CONFIG_ENCRYPTION_PASSWORD=
